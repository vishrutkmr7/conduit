{
  "configs": {
    "Debug": "debug",
    "Release": "release"
  },
  "name": "Conduit",
  "options": {
    "groupSortPosition": "bottom",
    "transitivelyLinkDependencies": false
  },
  "settings": {
    "CODE_SIGN_IDENTITY": "-"
  },
  "targets": {
    "Conduit": {
      "dependencies": [
        {
          "embed": true,
          "target": "Conduit Widget Extension"
        }
      ],
      "deploymentTarget": "27.0",
      "entitlements": {
        "path": "App/Conduit.entitlements",
        "properties": {
          "aps-environment": "development",
          "com.apple.security.app-sandbox": true,
          "com.apple.security.network.client": true,
          "com.apple.security.application-groups": [
            "group.app.bitrig.vishrutjha.conduit"
          ],
          "com.apple.developer.icloud-container-identifiers": [
            "iCloud.app.bitrig.vishrutjha.conduit"
          ],
          "com.apple.developer.icloud-services": [
            "CloudKit"
          ]
        }
      },
      "info": {
        "path": "App/Info.plist",
        "properties": {
          "CFBundleDisplayName": "Conduit",
          "CFBundleShortVersionString": "1.0",
          "CFBundleVersion": "1",
          "ITSAppUsesNonExemptEncryption": false,
          "LSApplicationCategoryType": "public.app-category.productivity",
          "UILaunchScreen": {},
          "UIBackgroundModes": [
            "remote-notification"
          ],
          "UISupportedInterfaceOrientations": [
            "UIInterfaceOrientationPortrait",
            "UIInterfaceOrientationPortraitUpsideDown",
            "UIInterfaceOrientationLandscapeLeft",
            "UIInterfaceOrientationLandscapeRight"
          ]
        }
      },
      "platform": "auto",
      "settings": {
        "ASSETCATALOG_COMPILER_APPICON_NAME": "AppIcon",
        "ASSETCATALOG_COMPILER_GLOBAL_ACCENT_COLOR_NAME": "AccentColor",
        "CURRENT_PROJECT_VERSION": "1",
        "MARKETING_VERSION": "1.0",
        "PRODUCT_BUNDLE_IDENTIFIER": "app.bitrig.vishrutjha.conduit",
        "PRODUCT_NAME": "$(TARGET_NAME)",
        "SWIFT_DEFAULT_ACTOR_ISOLATION": "MainActor",
        "SWIFT_STRICT_CONCURRENCY": "complete",
        "SWIFT_VERSION": "6.0",
        "TARGETED_DEVICE_FAMILY": "1,2"
      },
      "sources": [
        {
          "path": "App"
        },
        {
          "path": "Shared"
        }
      ],
      "supportedDestinations": [
        "iOS"
      ],
      "type": "application"
    },
    "Conduit Widget Extension": {
      "deploymentTarget": "27.0",
      "entitlements": {
        "path": "Widget Extension/Widget Extension.entitlements",
        "properties": {
          "com.apple.security.app-sandbox": true,
          "com.apple.security.application-groups": [
            "group.app.bitrig.vishrutjha.conduit"
          ],
          "com.apple.developer.icloud-container-identifiers": [
            "iCloud.app.bitrig.vishrutjha.conduit"
          ],
          "com.apple.developer.icloud-services": [
            "CloudKit"
          ]
        }
      },
      "info": {
        "path": "Widget Extension/Info.plist",
        "properties": {
          "CFBundleDisplayName": "Conduit Widget Extension",
          "CFBundleShortVersionString": "1.0",
          "CFBundleVersion": "1",
          "ITSAppUsesNonExemptEncryption": false,
          "NSExtension": {
            "NSExtensionPointIdentifier": "com.apple.widgetkit-extension"
          }
        }
      },
      "platform": "auto",
      "settings": {
        "APPLICATION_EXTENSION_API_ONLY": "YES",
        "CURRENT_PROJECT_VERSION": "1",
        "MARKETING_VERSION": "1.0",
        "PRODUCT_BUNDLE_IDENTIFIER": "app.bitrig.vishrutjha.conduit.widget-extension",
        "PRODUCT_NAME": "$(TARGET_NAME)",
        "SKIP_INSTALL": "YES",
        "SWIFT_DEFAULT_ACTOR_ISOLATION": "MainActor",
        "SWIFT_STRICT_CONCURRENCY": "complete",
        "SWIFT_VERSION": "6.0"
      },
      "sources": [
        {
          "path": "Widget Extension"
        },
        {
          "path": "Shared"
        }
      ],
      "supportedDestinations": [
        "iOS"
      ],
      "type": "app-extension"
    },
    "ConduitTests": {
      "dependencies": [
        {
          "target": "Conduit"
        }
      ],
      "deploymentTarget": "27.0",
      "platform": "iOS",
      "settings": {
        "GENERATE_INFOPLIST_FILE": "YES",
        "PRODUCT_BUNDLE_IDENTIFIER": "app.bitrig.vishrutjha.conduit.tests",
        "SWIFT_STRICT_CONCURRENCY": "complete",
        "SWIFT_VERSION": "6.0"
      },
      "sources": [
        {
          "path": "Tests/ConduitTests"
        }
      ],
      "type": "bundle.unit-test"
    },
    "ConduitAppIntentsTests": {
      "dependencies": [
        {
          "target": "Conduit"
        }
      ],
      "deploymentTarget": "27.0",
      "platform": "iOS",
      "settings": {
        "GENERATE_INFOPLIST_FILE": "YES",
        "PRODUCT_BUNDLE_IDENTIFIER": "app.bitrig.vishrutjha.conduit.appintents-tests",
        "SWIFT_STRICT_CONCURRENCY": "complete",
        "SWIFT_VERSION": "6.0",
        "TEST_TARGET_NAME": "Conduit"
      },
      "sources": [
        {
          "path": "Tests/ConduitAppIntentsTests"
        }
      ],
      "type": "bundle.ui-testing"
    }
  },
  "schemes": {
    "Conduit": {
      "build": {
        "targets": {
          "Conduit": "all",
          "Conduit Widget Extension": "all"
        }
      },
      "run": {
        "config": "Debug"
      },
      "test": {
        "config": "Debug",
        "targets": [
          "ConduitTests",
          "ConduitAppIntentsTests"
        ]
      }
    },
    "Conduit Widget Extension": {
      "build": {
        "targets": {
          "Conduit Widget Extension": "all"
        }
      },
      "run": {
        "config": "Debug"
      }
    }
  }
}
